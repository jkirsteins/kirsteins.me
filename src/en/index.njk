---
layout: layouts/base.njk
---
<h2>{{ "stuff_title" | i18n }}</h2>

<ul>
  <li><a href="https://vardulis.kirsteins.me" target="_blank" rel="noopener">Wordlike</a> — {{ "vardulis_description" | i18n }} <a href="https://apps.apple.com/us/app/wordlike/id1619500618" target="_blank" rel="noopener">App Store</a> and the <a href="https://vardulis.kirsteins.me" target="_blank" rel="noopener">web</a>.</li>
  <li><a href="https://murdle.kirsteins.me" target="_blank" rel="noopener">Murdle</a> — a daily murder mystery logic puzzle in English, Latvian, and Norwegian.</li>
  <li><a href="https://emojis.kirsteins.me" target="_blank" rel="noopener">Emojis</a> — a tiny tool for composing custom emoji mashups.</li>
  <li><a href="https://longhaul.kirsteins.me" target="_blank" rel="noopener">The Long Haul: 2247</a> — a browser-based sci-fi idle game about captaining a spaceship across the solar system.</li>
  <li><a href="https://brood.kirsteins.me" target="_blank" rel="noopener">The Long Haul: Brood</a> — an idle game set in the TRAPPIST-1 system, from an alien species' point of view.</li>
</ul>

{% set articles = collections.articles_all %}
{% if articles.length %}
<h2>Articles</h2>

<ul>
  {% for article in articles | reverse %}
  <li>
    <a href="{{ article.url }}">{{ article.data.title }}</a>
    <span class="muted">{{ article.date | dateDisplay(lang) }}</span>
    {% set langs = article | translations %}
    {% if langs.length > 1 %}
      <span class="muted">({% for t in langs %}<a href="{{ t.url }}">{{ t.lang }}</a>{% if not loop.last %} · {% endif %}{% endfor %})</span>
    {% endif %}
  </li>
  {% endfor %}
</ul>
{% endif %}
