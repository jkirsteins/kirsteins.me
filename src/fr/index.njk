---
layout: layouts/base.njk
---
<h2>{{ "stuff_title" | i18n }}</h2>

<ul>
  <li><img src="/img/wordlike-icon.png" alt="" class="app-icon"><a href="https://vardulis.kirsteins.me" target="_blank" rel="noopener">Wordlike</a> — {{ "vardulis_description" | i18n }}<a href="https://apps.apple.com/us/app/wordlike/id1619500618" target="_blank" rel="noopener">App Store</a> et sur le <a href="https://vardulis.kirsteins.me" target="_blank" rel="noopener">web</a>.</li>
  <li><img src="/img/vgw-icon.png" alt="" class="app-icon"><a href="https://apps.apple.com/app/very-good-workouts/id6743597895" target="_blank" rel="noopener">Very Good Workouts</a> — {{ "vgw_description" | i18n }}</li>
  <li><a href="https://murdle.kirsteins.me" target="_blank" rel="noopener">Murdle</a> — une énigme policière quotidienne en anglais, letton et norvégien.</li>
  <li><a href="https://emojis.kirsteins.me" target="_blank" rel="noopener">Emojis</a> — un petit outil pour créer des combinaisons d'émojis.</li>
  <li><a href="https://longhaul.kirsteins.me" target="_blank" rel="noopener">The Long Haul: 2247</a> — un jeu idle de science-fiction dans le navigateur où vous commandez un vaisseau à travers le système solaire.</li>
  <li><a href="https://brood.kirsteins.me" target="_blank" rel="noopener">The Long Haul: Brood</a> — un jeu idle dans le système TRAPPIST-1, du point de vue d'une espèce extraterrestre.</li>
</ul>

{% set articles = collections.articles_all %}
{% if articles.length %}
<h2>{{ "articles_title" | i18n }}</h2>

<ul>
  {% for article in articles | reverse %}
  <li>
    <a href="{{ article.url }}">{{ article.data.title }}</a>
    <span class="muted">{{ article.date | dateDisplay(lang) }}</span>
    {% set langs = article | translations %}
    {% if langs.length > 1 %}
      <span class="muted">({% for t in langs %}<a href="{{ t.url }}">{{ t.lang }}</a>{% if not loop.last %} · {% endif %}{% endfor %})</span>
    {% endif %}
  </li>
  {% endfor %}
</ul>
{% endif %}
