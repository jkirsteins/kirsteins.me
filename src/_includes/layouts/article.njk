---
layout: layouts/base.njk
---
<article>
  <header class="article-header">
    <time class="article-header__date" datetime="{{ date | dateDisplay('en') }}">
      {{ date | dateDisplay(page.lang) }}
    </time>
    <h1 class="page-title">{{ title }}</h1>
  </header>

  <div class="article-content">
    {{ content | safe }}
  </div>

  <a href="/{{ page.lang }}/" class="article-back">← Back</a>
</article>
