<h2>{{ "stuff_title" | i18n }}</h2>

<ul>
  <li><img src="/img/wordlike-icon.png" alt="" class="app-icon"><a href="https://vardulis.kirsteins.me" target="_blank" rel="noopener">Vārdulis</a> - {{ "vardulis_description" | i18n }} <a href="https://apps.apple.com/us/app/wordlike/id1619500618" target="_blank" rel="noopener">App Store</a> un <a href="https://vardulis.kirsteins.me" target="_blank" rel="noopener">tīmeklī</a>.</li>
  <li><img src="/img/vgw-icon.png" alt="" class="app-icon"><a href="https://apps.apple.com/app/very-good-workouts/id6760448353" target="_blank" rel="noopener">Ļoti labi treniņi</a> - {{ "vgw_description" | i18n }}</li>
  <li><img src="/img/webometer-icon.png" alt="" class="app-icon"><a href="https://apps.apple.com/app/webometer/id1629251250" target="_blank" rel="noopener">Vietņu taimeris</a> - {{ "webometer_description" | i18n }}</li>
  <li><a href="https://murdle.kirsteins.me" target="_blank" rel="noopener">Murdle</a> - ikdienas slepkavības mīkla angļu, latviešu un norvēģu valodā.</li>
  <li><a href="https://emojis.kirsteins.me" target="_blank" rel="noopener">Emojis</a> - neliels rīks emocijzīmju kombināciju veidošanai.</li>
  <li><a href="https://longhaul.kirsteins.me" target="_blank" rel="noopener">The Long Haul: 2247</a> - pārlūkprogrammas zinātniskās fantastikas dīkstāves spēle par kosmosa kuģa kapteiņa dzīvi Saules sistēmā.</li>
  <li><a href="https://brood.kirsteins.me" target="_blank" rel="noopener">The Long Haul: Brood</a> - dīkstāves spēle TRAPPIST-1 sistēmā, no citplanētiešu sugas skatupunkta.</li>
</ul>

{% set articles = collections.articles_all %}
{% if articles.length %}
<h2>{{ "articles_title" | i18n }}</h2>

<ul>
  {% for article in articles | reverse %}
  <li>
    <a href="{{ article.url }}">{{ article.data.title }}</a>
    <span class="muted">{{ article.date | dateDisplay(lang) }}</span>
    {% set langs = article | translations %}
    {% if langs.length > 1 %}
      <span class="muted">({% for t in langs %}<a href="{{ t.url }}">{{ t.lang }}</a>{% if not loop.last %} · {% endif %}{% endfor %})</span>
    {% endif %}
  </li>
  {% endfor %}
</ul>
{% endif %}
